# Mobile per-tenant dev config. Copy to `.env` (gitignored) and fill in.
# These are the only brand-adjacent values compiled into the build; everything visual still comes
# from the runtime manifest (GOLDEN RULE #5). See docs/RUNNING.md step 4.

# Seeded demo tenant UUID — paste the `tenant_id` printed by `uv run python -m app.seed`.
# Leave unset to use the committed demo fallback in src/config/buildConfig.ts.
TENANT_ID=

# Optional: override the dev API host (defaults: iOS localhost:8000, Android 10.0.2.2:8000).
# Set for a physical device, e.g. API_HOST=http://192.168.1.50:8000
API_HOST=
