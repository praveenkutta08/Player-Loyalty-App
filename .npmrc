# React Native's Metro bundler and Gradle/CocoaPods autolinking expect a flat, npm-style
# node_modules. pnpm's default isolated (symlinked) layout breaks RN dependency resolution, so
# the whole workspace uses a hoisted node_modules. Harmless for the Vite admin (apps/admin) and
# unrelated to the Python backend (uv).
node-linker=hoisted
