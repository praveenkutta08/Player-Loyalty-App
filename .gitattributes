# Normalize line endings to LF in the repo and on checkout — prettier enforces `endOfLine: lf`,
# so Windows clones with core.autocrlf=true would otherwise fail `pnpm format:check` on files
# git converted to CRLF.
* text=auto eol=lf

# Windows batch scripts must stay CRLF.
*.bat text eol=crlf

# Binaries.
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.keystore binary
*.jks binary
*.docx binary
