# ---- Backend ----
APP_ENV=dev
API_BASE_PATH=/api/v1
# Owner/migration DSN — used by alembic and `uv run python -m app.seed` only.
DATABASE_URL=postgresql+asyncpg://player:player@localhost:5433/player
# The API itself connects as the RLS-bound, non-superuser role created by migrations (audit C1).
# Run `alembic upgrade head` once, then leave these set. The app refuses to boot on a
# SUPERUSER/BYPASSRLS connection outside dev (dev-only escape hatch: ALLOW_SUPERUSER_DB=1).
PG_APP_USER=app_runtime
PG_APP_PASSWORD=app_runtime
REDIS_URL=redis://localhost:6379/0

# Auth (generate real secrets per environment; never commit)
JWT_SECRET=dev-only-insecure-change-me-32bytes-minimum
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# Rate limiting (audit H4) — Redis-backed fixed windows on login/OTP endpoints.
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_AUTH_PER_IP=30           # attempts / window / client IP / endpoint
# RATE_LIMIT_AUTH_PER_IDENTIFIER=10   # attempts / window / email (tenant-scoped)
# RATE_LIMIT_AUTH_WINDOW_S=60
# OTP_MAX_ATTEMPTS=5                  # wrong codes before the OTP dies (re-request needed)
# LOGIN_MAX_FAILURES=5                # failed admin logins before temporary lockout
# LOGIN_LOCKOUT_S=300

# Adapters: mock | sandbox | live  (MVP default = mock)
# Per-port *_PROVIDER overrides fall back to ADAPTER_MODE when unset.
ADAPTER_MODE=mock
LOYALTY_PROVIDER=mock
KYC_PROVIDER=mock
GEO_PROVIDER=mock
CASHLESS_PROVIDER=mock
DIGITAL_KEY_PROVIDER=mock
PAYMENT_PROVIDER=mock
PUSH_PROVIDER=mock
CHAT_PROVIDER=mock
# Mock adapter behaviour (0 = deterministic; raise failure rate in dev to test resilience)
MOCK_LATENCY_MS=0
MOCK_FAILURE_RATE=0.0

# Object storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=player-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Stable public base for object GET URLs (persisted on offers/content). Leave unset to serve from
# {S3_ENDPOINT}/{S3_BUCKET}. For the Android emulator to load dev-uploaded images, set it to the
# host-loopback bucket URL; in prod set a CDN/public bucket host.
#   Android emulator: S3_PUBLIC_BASE_URL=http://10.0.2.2:9000/player-media
# S3_PUBLIC_BASE_URL=

# Push (fill for real APNs/FCM; mock works without)
FCM_SERVICE_ACCOUNT_JSON=
APNS_KEY_ID=
APNS_TEAM_ID=

# ---- AI Concierge (Phase 6) ----
# External context providers: "mock" (offline demo) or "real" (Open-Meteo / OSRM, both keyless).
WEATHER_PROVIDER=mock
TRAVEL_PROVIDER=mock
# Narration: "mock" = scripted offline; "real" = Claude via ANTHROPIC_API_KEY.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5
# Cache (redis in docker-compose, graceful degradation to in-process memory).
CACHE_BACKEND=redis
WEATHER_CACHE_TTL_S=1800
TRAVEL_CACHE_TTL_S=300
CONCIERGE_ANSWER_CACHE_TTL_S=300

# ---- Frontends ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
