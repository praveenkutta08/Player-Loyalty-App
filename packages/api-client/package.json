{
  "name": "@repo/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "prettier": "@repo/config/prettier",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "generate": "openapi-typescript http://localhost:8000/api/v1/openapi.json --output src/generated/schema.ts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "@repo/shared-types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/react": "^18.3.5",
    "eslint": "^9.11.1",
    "openapi-typescript": "^7.4.1",
    "react": "^18.3.1",
    "typescript": "^5.6.2"
  }
}
